# Site
VITE_SITE_NAME=Blen

# Environment: production | development | local
VITE_ENVIRONMENT_MODE=production

# i18n — static translation bundles (en, ko)
# Browser language is preferred when supported; otherwise VITE_I18N_DEFAULT_LANG is used.
VITE_I18N_SUPPORTED_LANGS=en,ko
VITE_I18N_DEFAULT_LANG=en
